<html lang="en-GB">
<head>
	<meta charset="UTF-8" /><html>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Community Men In Sheds Taunton - {{ title }}</title>
  {% if eleventy.env.runMode == "serve" or eleventy.env.runMode == "watch" %}
    {% for name in cssFiles %}
    <link rel="stylesheet" href="/css/{{ name }}.css" />
    {% endfor %}
  {% else %}
    <link rel="stylesheet" href="/bundle.css" />
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Merriweather:ital,opsz,wght@0,18..144,300..900;1,18..144,300..900&display=swap" rel="stylesheet">


  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

</head>

<body>

<header>
  <div>
    <a href="/"><img src="/media/images/logo.png" alt="CMIST logo" height="80" /></a>
  </div>

  <nav>
    <input type="checkbox" id="nav-toggle" />
    <label for="nav-toggle" class="nav-toggle-label">
      <span></span>
    </label>
    {% set navItems = [
      { key: "home",       label: "Home",       url: "/" },
      { key: "about",      label: "About",      url: "/about" },
      { key: "projects",    label: "Projects",    url: "/projects" },
      { key: "facilities",  label: "Facilities",  url: "/facilities" },
      { key: "funding",     label: "Funding",     url: "/funding" },
      { key: "contact",    label: "Contact",    url: "/contact" }
    ] %}
    <ul>
      {% for item in navItems %}
      <li{% if navActive == item.key %} class="active"{% endif %}><a href="{{ item.url }}">{{ item.label }}</a></li>
      {% endfor %}
    </ul>
  </nav>
</header>

<main>
{{ content | safe }}
</main>


<footer class="flex gap-30 space-between">
  <div>
    <p>
          <strong>&copy; 2026 ommunity Men in Sheds Taunton<br />
      Registered Charity No.  1198052
      </strong>

    </p>

      <p><a href="https://www.facebook.com/CommunityMenInShedsTaunton/">
            <img src="/media/images/icons/fb.svg" alt="Facebook Logo" width="40"/></a>
      <a href="mailto:cmist.taunton@gmail.com">
            <img src="/media/images/icons/mail.svg" alt="Mail icon" width="40"/></a></p>

  </div>
  <div>
        <p>Unit 1<br /> 
          Old Engineering Workshops <br />
          Station Approach North <br />
          Taunton Station<br /> Taunton<br />TA1 1QP</p>
  </div>
</footer>

</body>
</html>
